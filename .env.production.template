# ══════════════════════════════════════════════════════════════════════════════
# Talent Trive Solution — PRODUCTION Environment Template
# ══════════════════════════════════════════════════════════════════════════════
# HOW TO USE THIS FILE:
#   1. Copy every variable below into:
#      Azure Portal → Your SWA → Settings → Environment variables
#   2. Also add each as a GitHub Secret:
#      GitHub repo → Settings → Secrets → Actions → New repository secret
#   3. NEVER rename this file to .env.production and commit real values.
#      Real secrets live only in Azure Portal and GitHub Secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Neon PostgreSQL (Free Tier — always on) ───────────────────────────────────
# Get this from: https://console.neon.tech → Your Project → Connection Details
# Use the "Pooled connection" string for production (supports serverless).
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXXX-XXXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# NEXTAUTH_URL must match your exact production domain (with https://).
NEXTAUTH_URL="https://www.talenttrive.com"

# Generate a secure secret with: openssl rand -hex 32
NEXTAUTH_SECRET="REPLACE_WITH_64_CHAR_HEX_STRING"

# ── Azure Active Directory (same App Registration as local dev) ───────────────
# Found in: Azure Portal → Azure Active Directory → App Registrations
AZURE_AD_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_AD_TENANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_AD_CLIENT_SECRET="your-client-secret-value"

# ── GitHub Actions — set this automatically by Azure when you link the repo ───
# AZURE_STATIC_WEB_APPS_API_TOKEN is injected by Azure; do not set it here.
